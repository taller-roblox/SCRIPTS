local npc = script.Parent
local humanoide = npc:WaitForChild("Humanoid")

while true do
    -- Buscamos la lista de todos los jugadores conectados
    local jugadores = game.Players:GetPlayers()
    
    -- Si hay por lo menos un jugador jugando...
    if #jugadores > 0 then
        local jugadorObjetivo = jugadores[1]
        local personajeJugador = jugadorObjetivo.Character
        
        if personajeJugador and personajeJugador:FindFirstChild("HumanoidRootPart") then
            -- Tomamos la posición de la raíz (el centro del cuerpo) del jugador
            local posicionJugador = personajeJugador.HumanoidRootPart.Position
            
            -- Le ordenamos al NPC caminar hacia ahí
            humanoide:MoveTo(posicionJugador)
        end
    end
    
    task.wait(0.5) -- Piensa cada medio segundo hacia dónde recalcular
end

